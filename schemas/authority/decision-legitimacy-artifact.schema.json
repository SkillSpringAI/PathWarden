{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pathwarden.decision-legitimacy-artifact.v1",
  "title": "PathWarden Decision Legitimacy Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "trace_id",
    "mode",
    "decision_code",
    "invariant_checks",
    "trigger_hits",
    "approval_state",
    "audit_required",
    "timestamp",
    "authority_chain",
    "authority_chain_hash",
    "authority_chain_hash_algorithm"
  ],
  "properties": {
    "schema_version": { "const": "decision-legitimacy-artifact.v1" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["core", "connect", "assistant", "locked_down"]
    },
    "decision_code": { "type": "string", "minLength": 1 },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "invariant_checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "trigger_hits": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approval_state": {
      "type": "string",
      "enum": ["not_required", "required_pending", "approved", "refused", "unknown"]
    },
    "capability_source": { "type": "string" },
    "audit_required": { "type": "boolean" },
    "timestamp": { "type": "string", "format": "date-time" },
    "authority_chain": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_chain_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "authority_chain_hash_algorithm": {
      "type": "string",
      "enum": ["sha256"]
    }
  }
}

