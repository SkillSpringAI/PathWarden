{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pathwarden Plan Schema",
  "type": "object",
  "required": ["plan_id", "actions", "risk_level", "requires_confirmation"],
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 3
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "../action/action.schema.json"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "requires_confirmation": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
