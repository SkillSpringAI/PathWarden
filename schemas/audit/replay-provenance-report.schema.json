{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PathWarden Replay Provenance Report Schema",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "created_at",
    "source",
    "authority",
    "replay",
    "trust",
    "revocation",
    "policy",
    "lineage",
    "summary",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["replay-provenance-report.v1"]
    },
    "report_id": {
      "type": "string",
      "minLength": 10
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "source": {
      "type": "object",
      "required": ["runtime", "environment"],
      "properties": {
        "runtime": {
          "type": "string",
          "enum": ["pathwarden"]
        },
        "environment": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["snapshot_id", "status"],
      "properties": {
        "snapshot_id": {
          "type": ["string", "null"]
        },
        "status": {
          "$ref": "#/definitions/status"
        }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "required": ["baseline_id", "diff_id", "execution_replay_refs", "status"],
      "properties": {
        "baseline_id": {
          "type": ["string", "null"]
        },
        "diff_id": {
          "type": ["string", "null"]
        },
        "execution_replay_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "$ref": "#/definitions/status"
        }
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "required": ["manifest_id", "status", "warnings", "critical_failures"],
      "properties": {
        "manifest_id": {
          "type": ["string", "null"]
        },
        "status": {
          "$ref": "#/definitions/status"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "critical_failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "revocation": {
      "type": "object",
      "required": ["checked", "status", "warnings", "critical_failures"],
      "properties": {
        "checked": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/definitions/status"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "critical_failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["manifest_id", "hashes_available", "status"],
      "properties": {
        "manifest_id": {
          "type": ["string", "null"]
        },
        "hashes_available": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/definitions/status"
        }
      },
      "additionalProperties": false
    },
    "lineage": {
      "type": "object",
      "required": ["complete", "explainable", "gaps", "notes"],
      "properties": {
        "complete": {
          "type": "boolean"
        },
        "explainable": {
          "type": "boolean"
        },
        "gaps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/lineage_gap"
          }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["status", "severity", "admissible", "recommendation", "notes"],
      "properties": {
        "status": {
          "$ref": "#/definitions/status"
        },
        "severity": {
          "type": "string",
          "enum": ["none", "info", "warning", "critical"]
        },
        "admissible": {
          "type": "boolean"
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/artifact_ref"
      }
    }
  },
  "definitions": {
    "status": {
      "type": "string",
      "enum": [
        "verified",
        "verified_with_warnings",
        "incomplete",
        "failed",
        "not_checked"
      ]
    },
    "lineage_gap": {
      "type": "object",
      "required": ["kind", "severity", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["none", "info", "warning", "critical"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "artifact_ref": {
      "type": "object",
      "required": ["kind", "id", "path", "required"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "authority_snapshot",
            "replay_baseline",
            "replay_diff",
            "policy_manifest"
          ]
        },
        "id": {
          "type": ["string", "null"]
        },
        "path": {
          "type": ["string", "null"]
        },
        "required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
