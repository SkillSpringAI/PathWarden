{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pathwarden Action Schema",
  "type": "object",
  "required": ["type", "operation"],
  "properties": {
    "type": {
      "type": "string",
      "const": "filesystem"
    },
    "operation": {
      "type": "string",
      "enum": [
        "list",
        "search",
        "move",
        "copy",
        "create",
        "rename",
        "delete",
        "open",
        "stat",
        "write"
      ]
    },
    "selector": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "destination": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "create": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": { "enum": ["move", "copy", "rename"] }
        }
      },
      "then": {
        "required": ["selector", "destination"]
      }
    },
    {
      "if": {
        "properties": {
          "operation": { "enum": ["delete", "open", "stat", "write"] }
        }
      },
      "then": {
        "required": ["selector"]
      }
    },
    {
      "if": {
        "properties": {
          "operation": { "const": "create" }
        }
      },
      "then": {
        "anyOf": [
          { "required": ["destination"] },
          { "required": ["create"] }
        ]
      }
    }
  ]
}
