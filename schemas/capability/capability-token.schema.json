{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pathwarden.capability-token.schema.v1",
  "title": "PathWarden Capability Token",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "token_id",
    "issuer_app_id",
    "subject_app_id",
    "capabilities",
    "created_at",
    "expires_at",
    "risk_ceiling",
    "requires_approval",
    "audit_required"
  ],
  "properties": {
    "token_id": {
      "type": "string",
      "minLength": 1
    },
    "issuer_app_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_app_id": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "path_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "risk_ceiling": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "requires_approval": {
      "type": "boolean"
    },
    "audit_required": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
