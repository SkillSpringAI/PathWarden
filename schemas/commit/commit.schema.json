{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pathwarden Commit Schema",
  "type": "object",
  "required": ["commit_id", "plan_id", "confirmed"],
  "properties": {
    "commit_id": {
      "type": "string",
      "minLength": 3
    },
    "plan_id": {
      "type": "string",
      "minLength": 3
    },
    "confirmed": {
      "type": "boolean",
      "const": true
    }
  },
  "additionalProperties": false
}
