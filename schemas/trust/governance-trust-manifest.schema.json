{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pathwarden.governance-trust-manifest.v1",
  "title": "PathWarden Governance Trust Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "trusted_signers"
  ],
  "properties": {
    "schema_version": {
      "const": "governance-trust-manifest.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "trusted_signers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signer_id",
          "public_key_fingerprint",
          "fingerprint_algorithm",
          "signature_algorithm",
          "status"
        ],
        "properties": {
          "signer_id": {
            "type": "string",
            "minLength": 1
          },
          "public_key_fingerprint": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          },
          "fingerprint_algorithm": {
            "type": "string",
            "enum": ["sha256"]
          },
          "signature_algorithm": {
            "type": "string",
            "enum": ["ed25519"]
          },
          "status": {
            "type": "string",
            "enum": ["trusted", "revoked", "suspended"]
          }
        }
      }
    }
  }
}